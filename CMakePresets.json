{
    "version": 6,
    "configurePresets": [
        {
            "name": "ninja",
            "displayName": "Ninja",
            "description": "Build using Ninja generator",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "BUILD_TESTS": "ON"
            }
        },
        {
            "name": "make",
            "displayName": "Unix Makefiles",
            "description": "Build using Unix Makefiles generator",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "BUILD_TESTS": "ON"
            }
        },
        {
            "name": "release",
            "displayName": "Release",
            "description": "Optimized release build with Ninja",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_TESTS": "OFF"
            }
        },
        {
            "name": "debug",
            "displayName": "Debug",
            "description": "Debug build with Ninja",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_TESTS": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "ninja",
            "configurePreset": "ninja"
        },
        {
            "name": "make",
            "configurePreset": "make"
        },
        {
            "name": "release",
            "configurePreset": "release"
        },
        {
            "name": "debug",
            "configurePreset": "debug"
        }
    ],
    "testPresets": [
        {
            "name": "ninja",
            "configurePreset": "ninja"
        },
        {
            "name": "make",
            "configurePreset": "make"
        },
        {
            "name": "debug",
            "configurePreset": "debug"
        }
    ]
}
